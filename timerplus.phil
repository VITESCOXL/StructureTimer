
TimerPlus{
  gui{
    location = 'tools'
      .type = str
      .help = The tab item where the TimerPlus GUI shall appear.
    before = 'images'
      .type = str
      .help = The tool before which the TimerPlus GUI shall appear.
    }
  refresh_interval = 3
    .type = int
    .help = Interval in seconds between automatic display refreshes (0 to disable).
}
